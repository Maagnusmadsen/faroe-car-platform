// FaroeRent – Production-ready marketplace schema
// PostgreSQL. Run: npx prisma generate, npx prisma migrate dev

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

// =============================================================================
// Enums
// =============================================================================

enum UserRole {
  USER   // can own listings and make bookings
  ADMIN
}

enum CarStatus {
  DRAFT
  ACTIVE
  PAUSED
  REJECTED
}

enum Transmission {
  automatic
  manual
}

enum FuelType {
  petrol
  diesel
  electric
  hybrid
}

enum VehicleType {
  car
  van
}

enum ListingType {
  car_rental
  ride_share
}

enum BookingStatus {
  PENDING_PAYMENT  // awaiting payment
  PENDING_APPROVAL // optional: awaiting owner approval (if approval flow used)
  CONFIRMED        // approved, payment done (or approved by owner)
  REJECTED         // owner rejected the request
  PAID             // payment succeeded, booking confirmed
  CANCELLED
  COMPLETED
  DISPUTED
}

enum PaymentType {
  CHARGE
  REFUND
  PAYOUT
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum PayoutStatus {
  PENDING
  COMPLETED
  FAILED
}

/// Future KYC/identity verification; not enforced in Step 4.
enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
}

enum NotificationType {
  BOOKING_REQUEST
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  PAYMENT_RECEIVED
  PAYOUT_SENT
  MESSAGE
  REVIEW_RECEIVED
  SYSTEM
}

// =============================================================================
// User & Auth (NextAuth-compatible)
// =============================================================================

model User {
  id                    String    @id @default(cuid())
  supabaseUserId        String?   @unique // Supabase auth.users.id; links to Supabase Auth
  email                 String    @unique
  emailVerified         DateTime?
  name                  String?
  image                 String?
  passwordHash          String?   // legacy NextAuth credentials; unused when using Supabase Auth
  role                  UserRole  @default(USER)
  stripeConnectAccountId String?  @unique // Stripe Connect Express account (acct_xxx) for receiving payouts
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  deletedAt             DateTime? // soft delete

  accounts         Account[]
  sessions         Session[]
  profile          UserProfile?
  carListings      CarListing[]       @relation("CarOwner")
  bookingsAsRenter Booking[]         @relation("BookingRenter")
  favorites        Favorite[]
  carReviewsGiven  CarReview[]        @relation("CarReviewReviewer")
  userReviewsGiven UserReview[]       @relation("UserReviewReviewer")
  userReviewsReceived UserReview[]    @relation("UserReviewReviewee")
  conversations    ConversationParticipant[]
  messagesSent     Message[]          @relation("MessageSender")
  notifications    Notification[]
  savedSearches    SavedSearch[]
  payouts          Payout[]
  auditLogs        AdminAuditLog[]     @relation("AuditLogActor")
}

model UserProfile {
  id                   String             @id @default(cuid())
  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone                String?
  avatarUrl            String?
  bio                  String?            @db.Text
  location             String?            // e.g. "Tórshavn, Faroe Islands"
  driverLicenseNumber  String?
  preferredLanguage    String?            @default("en")
  // Address / location (reusable for bookings, KYC)
  country              String?
  region               String?
  city                 String?
  postalCode           String?
  // Role-specific info (owner listing page, renter booking context)
  ownerNote            String?            @db.Text
  renterNote           String?            @db.Text
  // Renter verification: age + driving licence
  dateOfBirth          DateTime?          // for 18+ check; required when requesting renter approval
  licenseImageUrl      String?            // URL of uploaded licence image (front or combined)
  // Future identity verification
  verificationStatus   VerificationStatus @default(UNVERIFIED)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

// NextAuth.js / Auth.js standard models
model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime

  @@index([userId])
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// =============================================================================
// Car listings
// =============================================================================

model CarListing {
  id                  String      @id @default(cuid())
  ownerId             String
  owner               User        @relation("CarOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  title               String?     // display title; if null, fall back to brand + model + year
  listingType         ListingType @default(car_rental)
  brand               String
  model               String
  year                Int
  description         String      @db.Text
  status              CarStatus  @default(DRAFT)
  rejectionReason     String?    @db.Text   // admin/owner rejection note (when status = REJECTED)
  moderatedAt         DateTime?              // when status last changed by admin/owner
  pricePerDay         Decimal    @db.Decimal(10, 2)
  currency            String     @default("DKK")
  minRentalDays       Int        @default(1)
  weeklyDiscountPct   Decimal?   @db.Decimal(5, 2)
  monthlyDiscountPct  Decimal?   @db.Decimal(5, 2)
  location            String     // display string e.g. "Tórshavn"
  town                String
  island              String
  latitude            Decimal    @db.Decimal(9, 6)
  longitude           Decimal    @db.Decimal(9, 6)
  pickupLocation      String     // specific address/place
  airportPickup       Boolean    @default(false)
  pickupInstructions  String?    @db.Text
  seats               Int
  transmission        Transmission
  fuelType            FuelType
  vehicleType         VehicleType @default(car)
  is4x4               Boolean    @default(false)
  luggageCapacity     String?
  ratingAvg           Decimal?   @db.Decimal(3, 2)
  reviewCount         Int        @default(0)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  deletedAt           DateTime?

  images              CarImage[]
  features            CarFeature[]
  availabilityRule    CarAvailabilityRule?
  blockedDates        CarBlockedDate[]
  pickupOptions       PickupOption[]
  bookings            Booking[]
  favorites           Favorite[]
  carReviews          CarReview[]

  @@index([ownerId])
  @@index([status])
  @@index([town])
  @@index([island])
  @@index([status, town])
  @@index([status, pricePerDay])
  @@index([latitude, longitude])
}

model CarImage {
  id         String    @id @default(cuid())
  carId      String
  car        CarListing @relation(fields: [carId], references: [id], onDelete: Cascade)
  url        String    @db.Text
  sortOrder  Int       @default(0)
  storageKey String?   // S3 object key or local path for deletion
  createdAt  DateTime  @default(now())

  @@index([carId])
}

model CarFeature {
  id        String    @id @default(cuid())
  carId     String
  car       CarListing @relation(fields: [carId], references: [id], onDelete: Cascade)
  featureKey String   // e.g. "bluetooth", "child_seat"
  featureValue String? // optional value
  createdAt DateTime  @default(now())

  @@unique([carId, featureKey])
  @@index([carId])
}

model CarAvailabilityRule {
  id                   String    @id @default(cuid())
  carId                String    @unique
  car                  CarListing @relation(fields: [carId], references: [id], onDelete: Cascade)
  minNoticeDays        Int       @default(0)
  advanceBookingDays   Int       @default(365)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model CarBlockedDate {
  id        String    @id @default(cuid())
  carId     String
  car       CarListing @relation(fields: [carId], references: [id], onDelete: Cascade)
  date      DateTime  @db.Date
  reason    String?   @db.Text
  createdAt DateTime  @default(now())

  @@unique([carId, date])
  @@index([carId])
  @@index([date])
}

model PickupOption {
  id        String    @id @default(cuid())
  carId     String
  car       CarListing @relation(fields: [carId], references: [id], onDelete: Cascade)
  label     String
  address   String?   @db.Text
  latitude  Decimal?  @db.Decimal(9, 6)
  longitude Decimal?  @db.Decimal(9, 6)
  isDefault Boolean   @default(false)
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([carId])
}

// =============================================================================
// Bookings
// =============================================================================

model Booking {
  id                   String        @id @default(cuid())
  carId                String
  car                  CarListing    @relation(fields: [carId], references: [id], onDelete: Restrict)
  renterId             String
  renter               User          @relation("BookingRenter", fields: [renterId], references: [id], onDelete: Restrict)
  startDate            DateTime      @db.Date
  endDate              DateTime      @db.Date
  status               BookingStatus @default(PENDING_PAYMENT)
  totalPrice           Decimal       @db.Decimal(10, 2)
  currency             String        @default("DKK")
  platformFeeAmount    Decimal       @db.Decimal(10, 2)
  ownerPayoutAmount    Decimal       @db.Decimal(10, 2)
  pickupLocationSnapshot String?     @db.Text
  payoutId             String?
  payout               Payout?       @relation(fields: [payoutId], references: [id], onDelete: SetNull)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  statusHistory BookingStatusHistory[]
  payments      Payment[]
  conversation  Conversation?
  carReviews    CarReview[]
  userReviews   UserReview[]

  @@index([carId])
  @@index([renterId])
  @@index([status])
  @@index([renterId, status, endDate])
  @@index([startDate, endDate])
  @@index([carId, startDate, endDate])
  @@index([payoutId])
}

model BookingStatusHistory {
  id        String        @id @default(cuid())
  bookingId String
  booking   Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  status    BookingStatus
  note      String?       @db.Text
  createdAt DateTime      @default(now())

  @@index([bookingId])
}

// =============================================================================
// Payments & Payouts
// =============================================================================

model Payment {
  id                   String        @id @default(cuid())
  bookingId            String?
  booking              Booking?      @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  type                 PaymentType
  amount               Decimal       @db.Decimal(10, 2)
  currency             String        @default("DKK")
  status               PaymentStatus @default(PENDING)
  stripePaymentIntentId String?     @unique
  stripeTransferId     String?
  metadata             Json?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([bookingId])
  @@index([status])
}

model Payout {
  id               String      @id @default(cuid())
  userId           String
  user             User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  amount           Decimal     @db.Decimal(10, 2)
  currency         String      @default("DKK")
  status           PayoutStatus @default(PENDING)
  stripeTransferId String?
  paidAt           DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  bookings         Booking[]

  @@index([userId])
  @@index([status])
  @@index([userId, createdAt])
}

// =============================================================================
// Reviews (only after completed booking)
// Renter → CarReview (reviews car). Owner → UserReview (reviews renter).
// =============================================================================

model CarReview {
  id         String     @id @default(cuid())
  bookingId  String
  booking    Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reviewerId String     // renter
  reviewer   User       @relation("CarReviewReviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  carId      String
  car        CarListing @relation(fields: [carId], references: [id], onDelete: Cascade)
  rating     Int        // 1-5
  comment    String?    @db.Text
  createdAt  DateTime   @default(now())

  @@unique([bookingId])
  @@index([carId])
  @@index([reviewerId])
}

model UserReview {
  id         String   @id @default(cuid())
  bookingId  String
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reviewerId String   // owner
  reviewer   User     @relation("UserReviewReviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  revieweeId String   // renter
  reviewee   User     @relation("UserReviewReviewee", fields: [revieweeId], references: [id], onDelete: Cascade)
  rating     Int      // 1-5
  comment    String?  @db.Text
  createdAt  DateTime @default(now())

  @@unique([bookingId])
  @@index([reviewerId])
  @@index([revieweeId])
}

// =============================================================================
// Messaging
// =============================================================================

model Conversation {
  id        String   @id @default(cuid())
  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt       DateTime     @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  body           String       @db.Text
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([conversationId])
  @@index([senderId])
  @@index([conversationId, createdAt])
}

// =============================================================================
// Favorites & Saved search
// =============================================================================

model Favorite {
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  carId     String
  car       CarListing @relation(fields: [carId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@id([userId, carId])
  @@index([userId])
  @@index([carId])
}

model SavedSearch {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String?
  query       Json     // filters: location, dates, price, etc.
  notifyEmail Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
}

// =============================================================================
// Notifications
// =============================================================================

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String?          @db.Text
  data      Json?            // e.g. { bookingId, conversationId }
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([userId, readAt])
}

// =============================================================================
// Admin & Platform config
// =============================================================================

model AdminAuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation("AuditLogActor", fields: [userId], references: [id], onDelete: SetNull)
  action     String
  entityType String
  entityId   String?
  payload    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model PlatformFeeConfig {
  id            String    @id @default(cuid())
  feeType       String    // "percentage" | "fixed"
  value         Decimal   @db.Decimal(10, 4) // e.g. 15 for 15%, or amount in DKK
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([effectiveFrom, effectiveTo])
}
